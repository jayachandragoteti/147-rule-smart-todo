rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Todo Management: Users can only access their own todos subcollection
    match /users/{userId}/todos/{todoId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Journal Management: Users can only access journal entries where they are the owner
    match /journals/{journalId} {
      // Allow reading if the authenticated user's ID matches the document's userId field
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Allow creation if the user is authenticated and is setting themselves as the owner
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow updates/deletion only if the user owns the existing document
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 3. Global Safety: Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
